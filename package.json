{
  "name": "@ant-code/cli",
  "version": "1.1.1",
  "description": "AGPL-licensed local coding agent with a terminal UI, local dashboard, tool permissions, skills, MCP integration, and model gateway adapters.",
  "type": "module",
  "private": true,
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wicm84266964/Ant-Code.git"
  },
  "bugs": {
    "url": "https://github.com/wicm84266964/Ant-Code/issues"
  },
  "homepage": "https://github.com/wicm84266964/Ant-Code#readme",
  "bin": {
    "ant-code": "./src/cli/index.js",
    "lab-agent": "./src/cli/index.js"
  },
  "files": [
    "lab-agent.config.json",
    "THIRD_PARTY_NOTICES.md",
    "config/lab-agent.high-sensitivity-template.json",
    "config/lab-agent.lab-template.json",
    "config/skills/",
    "docs/deployment/local-installation.md",
    "docs/deployment/model-adapter-gateway-readiness.md",
    "docs/deployment/quickstart.md",
    "docs/security/data-boundary.md",
    "scripts/audit-common.js",
    "scripts/build-dashboard-assets.js",
    "scripts/build-windows-exe.js",
    "scripts/check-syntax.js",
    "scripts/dependency-audit-common.js",
    "scripts/generate-dependency-sbom.js",
    "scripts/generate-endpoint-manifest.js",
    "scripts/generate-license-summary.js",
    "scripts/github-mcp-server.js",
    "scripts/mock-gateway.js",
    "scripts/verify-dependency-policy.js",
    "scripts/verify-forbidden-endpoints.js",
    "scripts/verify-gateway-compat.js",
    "scripts/verify-install.js",
    "scripts/verify-readiness-docs.js",
    "scripts/verify-release-seal.js",
    "src/",
    "npm-shrinkwrap.json",
    "package-lock.json",
    "tsconfig.json"
  ],
  "scripts": {
    "start": "node src/cli/index.js",
    "doctor": "node src/cli/index.js doctor",
    "mock-gateway": "node scripts/mock-gateway.js",
    "verify:install": "node scripts/verify-install.js",
    "check": "npm run check:syntax && npm run check:forbidden && npm run check:dependencies && npm test",
    "check:syntax": "node scripts/check-syntax.js",
    "check:forbidden": "node scripts/verify-forbidden-endpoints.js",
    "check:release-seal": "node scripts/verify-release-seal.js",
    "check:dependencies": "node scripts/verify-dependency-policy.js",
    "verify:gateway": "node scripts/verify-gateway-compat.js",
    "verify:readiness": "node scripts/verify-readiness-docs.js",
    "audit:endpoints": "node scripts/generate-endpoint-manifest.js",
    "audit:sbom": "node scripts/generate-dependency-sbom.js",
    "audit:licenses": "node scripts/generate-license-summary.js",
    "audit": "npm run audit:endpoints && npm run audit:sbom && npm run audit:licenses",
    "build:dashboard-assets": "node scripts/build-dashboard-assets.js",
    "build:exe": "node scripts/build-windows-exe.js",
    "verify:release": "npm run check && npm run verify:install && npm run verify:gateway && npm run verify:readiness && npm run check:release-seal && npm run audit",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "katex": "^0.16.46",
    "mermaid": "^11.15.0",
    "react": "^19.2.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "postject": "^1.0.0-alpha.6"
  }
}
